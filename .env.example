# Root env for docker-compose. Copy to .env and fill in.
# (For local non-Docker dev, use backend/.env.development.local instead.)

NODE_ENV=production
BACKEND_PORT=3001
FRONTEND_PORT=3000

# BFF
BASE_URL_PREFIX=/api
SECRET_KEY=change-me-to-a-long-random-string
ORIGIN=http://localhost:3000
CREDENTIALS=true

# WSO2 / Citizen (test)
API_BASE_URL=https://api-test.sundsvall.se
CLIENT_KEY={{INSERT CLIENT_KEY}}
CLIENT_SECRET={{INSERT CLIENT_SECRET}}
MUNICIPALITY_ID=2281

# Mocked citizen user (BankID) - real personId (uuid) used against Citizen
CITIZEN_PERSON_ID={{INSERT_PERSON_UUID}}
CITIZEN_PERSON_NUMBER={{INSERT_PERSONNUMMER}}
CITIZEN_NAME=Test Testsson

# Admin login via SAML against the fake SSO IdP (web-app-fake-sso-idp)
SAML_ENTRY_SSO=http://localhost:7000/sso
SAML_CALLBACK_URL=http://localhost:3001/api/saml/login/callback
SAML_LOGOUT_CALLBACK_URL=http://localhost:3001/api/saml/logout/callback
SAML_SUCCESS_REDIRECT=http://localhost:3000/admin/dashboard
SAML_FAILURE_REDIRECT=http://localhost:3000/admin
SAML_ISSUER=web-app-raddningstjansten
SAML_IDP_PUBLIC_CERT="-----BEGIN CERTIFICATE-----\n{{INSERT_IDP_PUBLIC_CERT}}\n-----END CERTIFICATE-----\n"
ADMIN_GROUP=Raddningstjansten-AVD-CHEFER

# Where frontend nginx proxies /api (compose service name)
BACKEND_URL=http://backend:3000
